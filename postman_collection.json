    {
      "name": "Catalog",
      "description": "Book catalog management endpoints.",
      "item": [
        {
          "name": "Get All Books (public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is JSON', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response has _links (HATEOAS)', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('_links');",
                  "    pm.expect(body._links).to.have.property('self');",
                  "});",
                  "",
                  "pm.test('No auth required for GET /catalog/books', function () {",
                  "    pm.response.to.not.have.status(401);",
                  "    pm.response.to.not.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/catalog/books",
              "host": ["{{baseUrl}}"],
              "path": ["catalog", "books"]
            }
          }
        },
        {
          "name": "Search Books by Title",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has _links (HATEOAS)', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('_links');",
                  "});",
                  "",
                  "pm.test('Self link points to /catalog/books', function () {",
                  "    const body = pm.response.json();",
                  "    const selfHref = body._links.self.href;",
                  "    pm.expect(selfHref).to.include('/catalog/books');",
                  "});",
                  "",
                  "pm.test('If results exist, each book has title and isbn', function () {",
                  "    const body = pm.response.json();",
                  "    if (body._embedded && body._embedded.bookResponseList) {",
                  "        body._embedded.bookResponseList.forEach(function (book) {",
                  "            pm.expect(book).to.have.property('title');",
                  "            pm.expect(book).to.have.property('isbn');",
                  "            pm.expect(book._links).to.have.property('self');",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/catalog/books?title=Clean",
              "host": ["{{baseUrl}}"],
              "path": ["catalog", "books"],
              "query": [{ "key": "title", "value": "Clean" }]
            }
          }
        },
