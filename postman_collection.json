{
  "info": {
    "name": "DDD Library API",
    "description": "Comprehensive test collection for the DDD Library Spring Boot application.\n\nModules covered:\n- Authentication (JWT)\n- Book Catalog management\n- Book Lending (rent/return)\n\nDefault users (seeded by Bootstrap.java):\n- admin / admin123 → ADMIN role\n- librarian / lib123 → LIBRARIAN role\n- patron / pat123 → PATRON role\n\nRun order: Auth → Catalog → Lending",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "librarianToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "patronToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "testIsbn",
      "value": "9780132350884",
      "type": "string",
      "description": "ISBN for 'Clean Code' by Robert C. Martin"
    },
    {
      "key": "testBarCode",
      "value": "BC-9780132350884-001",
      "type": "string"
    },
    {
      "key": "testAuthorEmail",
      "value": "martin@example.com",
      "type": "string",
      "description": "Contact email (domain identity) of the author used in catalog tests"
    },
    {
      "key": "activeLoanId",
      "value": "",
      "type": "string",
      "description": "Set dynamically after renting a book"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints. Run these first to populate tokens used by subsequent requests.",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has token field', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Token is a valid JWT (three base64 parts)', function () {",
                  "    const token = pm.response.json().token;",
                  "    const parts = token.split('.');",
                  "    pm.expect(parts).to.have.lengthOf(3);",
                  "});",
                  "",
                  "// Save token for use by other requests",
                  "const token = pm.response.json().token;",
                  "pm.collectionVariables.set('adminToken', token);",
                  "console.log('Admin token saved.');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
